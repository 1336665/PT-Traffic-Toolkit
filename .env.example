# PT Manager Pro Environment Configuration

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=change-this-to-a-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/pt_manager.db

# Debug mode
DEBUG=false

# CORS - In production, set to your frontend domain(s)
# Use comma-separated values for multiple origins
# Examples:
#   CORS_ORIGINS=http://localhost:8080
#   CORS_ORIGINS=https://pt.yourdomain.com
#   CORS_ORIGINS=https://pt.yourdomain.com,http://localhost:8080
# Use "*" to allow all origins (not recommended for production)
CORS_ORIGINS=*

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
